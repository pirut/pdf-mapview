{
  "name": "pdf-mapview",
  "version": "0.1.0",
  "description": "React viewer and ingest toolkit for map-like PDF, floorplan, and large image experiences.",
  "keywords": [
    "pdf",
    "floorplan",
    "tiles",
    "deep-zoom",
    "openseadragon",
    "react",
    "tanstack-start",
    "vercel",
    "ingest",
    "viewer"
  ],
  "author": "JR Bussard",
  "license": "0BSD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pirut/pdf-mapview.git"
  },
  "homepage": "https://github.com/pirut/pdf-mapview#readme",
  "bugs": {
    "url": "https://github.com/pirut/pdf-mapview/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "main": "./dist/shared/index.cjs",
  "module": "./dist/shared/index.js",
  "types": "./dist/shared/index.d.ts",
  "bin": {
    "pdf-mapview": "./dist/ingest/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "require": "./dist/shared/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./ingest": {
      "types": "./dist/ingest/index.d.ts",
      "import": "./dist/ingest/index.js",
      "require": "./dist/ingest/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage .vitest"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.67",
    "cac": "^6.7.14",
    "openseadragon": "^5.0.1",
    "pdfjs-dist": "^4.10.38",
    "sharp": "^0.34.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "pdf-lib": "^1.17.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
